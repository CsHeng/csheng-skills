{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skills-dev.local/schemas/adversarial-reviewer-output.schema.json",
  "title": "Adversarial Reviewer Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lens",
    "verdict",
    "summary",
    "findings",
    "pass_rationale"
  ],
  "properties": {
    "lens": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "pass_rationale": {
      "type": "string"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "location",
        "evidence",
        "impact",
        "fix",
        "confidence"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["Critical", "Important", "Minor"]
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "fix": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  }
}
