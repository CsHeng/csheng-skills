@startuml
' Generated from src/skills/workflows/implement-change/references/workflow.toml; do not edit by hand.
title Controller-Owned Implementation Repair Loop
hide empty description
skinparam shadowing false
skinparam state {
  BackgroundColor #F8FAFC
  BorderColor #475569
}

state "implement" as n_implement
state "verify" as n_verify
state "review" as n_review
state "classify" as n_classify
state "diagnose" as n_diagnose
state "repair" as n_repair
state "pass" as n_exit_pass <<exit>>
state "replan" as n_exit_replan <<exit>>
state "redesign" as n_exit_redesign <<exit>>
state "needs-authority" as n_exit_needs_authority <<exit>>
state "rollback" as n_exit_rollback <<exit>>
state "non-convergent" as n_exit_non_convergent <<exit>>

[*] --> n_implement
n_implement --> n_verify : task slice complete
n_verify --> n_review : declared oracles complete
n_review --> n_classify : fresh full verdict
n_classify --> n_diagnose : accepted local repair
n_diagnose --> n_repair : root-cause hypothesis
n_repair --> n_verify : batched in-scope fix
n_classify --> n_exit_pass : review + verification pass
n_exit_pass --> [*]
n_classify --> n_exit_replan : typed boundary
n_exit_replan --> [*]
n_classify --> n_exit_redesign : typed boundary
n_exit_redesign --> [*]
n_classify --> n_exit_needs_authority : typed boundary
n_exit_needs_authority --> [*]
n_classify --> n_exit_rollback : typed boundary
n_exit_rollback --> [*]
n_classify --> n_exit_non_convergent : typed boundary
n_exit_non_convergent --> [*]

note right of n_repair
  Owner: implement-change
  Expected convergence: 5 rounds
  Hard limit: 10 rounds
  One round repairs the complete accepted finding batch.
end note
@enduml
